; Engine configuration file.
; Lanternhouse — retro JRPG prototype
; Controller-friendly with pixel-art support

config_version=5

[application]
config/name="Lanternhouse"
run/main_scene="res://scenes/overworld/overworld.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"
config/description="Lanternhouse — a retro 8-bit JRPG prototype built with Godot 4. Overworld exploration, turn-based combat, town shops, and a warm lanternlit aesthetic. See docs/ for pixel-art direction and asset conventions."

[autoload]
GameData="*res://scripts/game_data.gd"
SpriteCache="*res://scripts/sprite_cache.gd"

[display]
window/size/viewport_width=960
window/size/viewport_height=640
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

